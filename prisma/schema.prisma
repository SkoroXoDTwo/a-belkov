generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Photo {
  id        String   @id @default(uuid())
  caption   String?
  imagePath String
  takenAt   DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([takenAt(sort: Desc)])
  @@map("photos")
}
